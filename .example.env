# Supabase Database Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication Config
JWT_SECRET=your-custom-jwt-secret-min-32-chars
NEXTAUTH_SECRET=your-next-auth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (NextAuth Provider)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay Payment Gateway
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Service Integration
EMAIL_SERVICE_URL=https://your-email-service-url.app/api/send
EMAIL_SERVICE_API_KEY=your-secure-api-access-key
